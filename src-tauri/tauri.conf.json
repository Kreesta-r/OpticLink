{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpticLink",
  "version": "0.2.0",
  "identifier": "com.user.opticlink",
  "build": {
    "beforeDevCommand": "npm run build && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpticLink",
        "width": 960,
        "height": 620,
        "minWidth": 800,
        "minHeight": 540,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "sidebarImage": "icons/sidebar.bmp",
        "headerImage": "icons/header.bmp",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}